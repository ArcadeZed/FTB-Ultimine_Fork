{
	"schemaVersion": 1,
	"icon": "icon.png",
	"id": "ftbultimine",
	"version": "${version}",
	"name": "FTB Ultimine",
	"description": "Allows you to break multiple blocks at once.",
	"authors": [
		"FTB Team"
	],
	"contact": {
		"sources": "https://github.com/FTBTeam/FTB-Ultimine",
		"issues": "https://go.ftb.team/support-mod-issues"
	},
	"license": "All Rights Reserved",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.ftb.mods.ftbultimine.fabric.FTBUltimineFabric"
		],
		"client": [
			"dev.ftb.mods.ftbultimine.fabric.FTBUltimineFabricClient"
		]
	},
	"mixins": [
		"ftbultimine-common.mixins.json",
		"ftbultimine-fabric.mixins.json"
	],
	"depends": {
		"fabric-api": "${fabricapi_version_range}",
		"minecraft": "${minecraft_version_range_semver}",
		"ftblibrary": "${ftb_library_version_range_semver}"
	}
}
